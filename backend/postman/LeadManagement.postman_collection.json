{
  "info": {
    "name": "Lead Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "List Leads",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/leads?page=1&limit=8"
          }
        },
        {
          "name": "Get Lead",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/leads/1"
          }
        },
        {
          "name": "Create Lead",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/leads",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sample Lead\",\n  \"email\": \"sample.lead@example.com\",\n  \"phone\": \"+1-555-0100\",\n  \"company\": \"Demo Co\",\n  \"position\": \"Buyer\",\n  \"source\": \"Website\",\n  \"priority\": \"High\",\n  \"assignedSalesRepId\": null\n}"
            }
          }
        },
        {
          "name": "Convert Lead",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/leads/3/convert"
          }
        },
        {
          "name": "Lead Interactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/leads/1/interactions"
          }
        },
        {
          "name": "Add Interaction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/leads/1/interactions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Called customer\",\n  \"interactionDate\": \"2026-03-28T10:00:00Z\",\n  \"followUpDate\": \"2026-04-05T10:00:00Z\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "By Source",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/analytics/by-source"
          }
        },
        {
          "name": "By Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/analytics/by-status"
          }
        },
        {
          "name": "Conversion Rate",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/analytics/conversion-rate"
          }
        },
        {
          "name": "By Sales Rep",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/analytics/by-salesrep"
          }
        }
      ]
    }
  ]
}
